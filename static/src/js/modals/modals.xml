<?xml version="1.0" encoding="utf-8" ?>
<templates>
    <t t-name="siat_client.modal-void" owl="1">
        <Dialog t-props="{'title': props.title, footer: true}">
            <div id="com-siat-void-invoice">
                <form ref="form" class="" novalidate="true">
                    <div class="row">
                        <div class="col-12 col-sm-6">
                            <div class="mb-3">
                                <label>Cliente</label>
                                <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.customer" />
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="mb-3">
                                <label>Nro. Factura</label>
                                <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.invoice_number" />
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="mb-3">
                                <label>Fecha emision</label>
                                <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.invoice_date_time" />
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="mb-3">
                                <label>Sucursal</label>
                                <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.codigo_sucursal" />
                            </div>
                        </div>
                        <div class="col-12 col-sm-6">
                            <div class="mb-3">
                                <label>Punto de Venta</label>
                                <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.punto_venta" />
                            </div>
                        </div>

                    </div>
                    <div class="mb-3">
                        <label>CUF</label>
                        <input type="text" readonly="true" class="form-control" t-att-value="props.invoice.cuf" />
                    </div>
                    <div class="mb-3">
                        <label>Motivo anulacion</label>
                        <select class="form-select" required="true" pattern="[1-9]+" t-on-change="handleMotivo">
                            <option value="0">-- motivo anulacion --</option>
                            <t t-foreach="props.motivos" t-as="m" t-key="m.codigoClasificador">
                                <option t-att-value="m.codigoClasificador"><t t-esc="m.descripcion" /></option>
                            </t>
                        </select>
                    </div>
                </form>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-danger o-default-button" t-on-click="() => data.close()">
                    <t>Cerrar</t>
                </button>
                <button type="button" class="btn btn-primary" t-on-click="onVoid">Anular</button>
            </t>
        </Dialog>
    </t>
    <t t-name="siat_client.modal-ops" owl="1">
        <Dialog t-props="{'title': props.title, footer: true}">
            <div class="form-grooup mb-2">
                <label>Sucursal</label>
                <select class="form-control form-select" t-model="props.invoice.codigo_sucursal">
                    <option value="0">Sucursal Principal 0 (por defecto)</option>
                    <t t-foreach="props.sucursales" t-as="s" t-key="s_index">
                        <option t-att-value="s.codigo"><t t-out="s.nombre" /></option>
                    </t>
                </select>
            </div>
            <div class="form-group mb-2">
                <label>Documento Sector</label>
                <select class="form-control form-select" t-model.number="props.invoice.codigo_documento_sector"
                    t-on-change="onSectorChanged" t-ref="sectoresEl">
                    <option value="">-- documento sector --</option>
                    <t t-foreach="props.sectores" t-as="ds" t-key="ds_index">
                        <option t-att-value="ds[1].code" t-att-data-code="ds[0]">
                            <t t-out="ds[1].label" />
                        </option>
                    </t>
                </select>
            </div>
            <t t-set-slot="footer">
                <button class="btn btn-danger o-default-button" t-on-click="() => data.close()">
                    <t>Cerrar</t>
                </button>
            </t>
        </Dialog>
    </t>
    <t t-name="siat_client.modal-customer">
        <Dialog t-props="{'title': props.title, footer: true}">
            <form t-ref="formcustomer" novalidate="">
                <div class="mb-2">
                    <label>Nombres</label>
                    <input type="text" class="form-control" t-model="state.customer.firstname" />
                    <div class="invalid-feedback">Ingrese el nombre del cliente</div>
                </div>
                <div class="mb-2">
                    <label>Apellidos/Razon Social</label>
                    <input type="text" class="form-control" t-model="state.customer.lastname" required="" />
                    <div class="invalid-feedback">Ingrese el apellido del cliente</div>
                </div>
                <div class="mb-2">
                    <label>NIT/CI</label>
                    <input type="text" class="form-control" t-model="state.customer.vat" required="" />
                    <div class="invalid-feedback">Ingrese el NIT/CI del cliente</div>
                </div>
                <div class="mb-2">
                    <label>Direccion</label>
                    <input type="text" class="form-control" t-model="state.customer.street" />
                    <div class="invalid-feedback">Ingrese la direccion del cliente</div>
                </div>
                <div class="mb-2">
                    <label>Email</label>
                    <input type="email" class="form-control" t-model="state.customer.email" />
                </div>
            </form>
            <t t-set-slot="footer">
                <button class="btn btn-danger o-default-button" t-on-click="() => data.close()">
                    <t>Cerrar</t>
                </button>
                <button type="button" class="btn btn-primary" t-on-click="guardarCliente">Guardar</button>
            </t>
        </Dialog>
    </t>
    <t t-name="siat_client.modal-print-invoice">
        <Dialog t-props="{'title': props.title, footer: true}">
            <div class="col-3 text-center">
                <i class="fa fa-print" style="font-size:50px;"></i>
            </div>
            <div class="col-9">
                <p>La factura fue generada correctamente</p>
                <p>Desea imprimir la factura?</p>
            </div>
            <t t-set-slot="footer">
                <button type="button" class="btn btn-danger o-default-button" t-on-click="() => data.close()">
                    Cerrar
                </button>
                <t t-if="props.invoice">
                    <a t-att-href="props.invoice.print_url"
                        target="_blank"
                        class="btn btn-primary"
                        t-on-click="() => data.close()">
                        Imprimir
                    </a>
                    <a t-att-href="print_url_ticket" target="_blank" class="btn btn-warning" t-on-click="() => data.close()">
                        Imprimir Ticket
                    </a>
                    <a t-att-href="print_url_receipt" target="_blank" class="btn btn-success" t-on-click="() => data.close()">
                        Imprimir Comprobante
                    </a>
                </t>

            </t>
        </Dialog>
    </t>
    <t t-name="siat_client.modal-tarjeta">
        <Dialog t-props="{'title': props.title, footer: true}">
        <form t-ref="formtarjeta" novalidate="">
            <p>Ingrese los datos de la tarjeta de credito/debito</p>
            <div class="mb-3">
                <label>Nro. de Tarjeta</label>
                <div class="input-group">
                    <span class="input-group-addon input-group-text "><i class="fa fa-credit-card"></i></span>
                    <input type="text" class="form-control" required="" pattern="[0-9]{16}"
                        maxlength="16" t-ref="inputcard"
                        t-on-keydown="(ev) => this.handleKeydown(ev)"
                        t-on-keyup="(ev) => this.handleKeyup(ev)"
                    />
                    <div class="invalid-feedback">Debe ingresar un numero de tarjeta valido</div>
                </div>
            </div>
            <t t-set-slot="footer">
                <button type="button" class="btn btn-danger" t-on-click="() => data.close()">Cancelar</button>
                <button type="button" class="btn btn-primary" t-on-click="save">Continuar</button>
            </t>
        </form>
        </Dialog>
    </t>
    <t t-name="siat_client.modal-excepcion">
        <Dialog t-props="{'title': props.title, footer: true}">
            <div class="col-3 text-center">
                <i class="fa fa-exclamation" style="font-size:50px;"></i>
            </div>
            <div class="col-9">
                <p>El NIT del cliente no es valido</p>
                <p>Desea generar la factura de todas formas?</p>
            </div>
            <t t-set-slot="footer">
                <button type="button" class="btn btn-danger" t-on-click="() => data.close()">Cerrar</button>
                <button type="button" class="btn btn-primary" t-on-click="submit">
                    Generar Factura
                </button>
            </t>
        </Dialog>
    </t>
</templates>