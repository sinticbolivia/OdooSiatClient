<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>
        <record id="siat_view_move_form" model="ir.ui.view">
            <field name="name">account.move.form</field>
            <field name="model">account.move</field>
            <field name="inherit_id" ref="account.view_move_form" />
            <field name="arch" type="xml">
                <xpath expr="//sheet/notebook" position="inside">
                    <page id="siat_info_tab" string="Facturacion SIAT" name="siat_info">
                        <group>
                            <group id="header_left_group">
                                <field name="invoice_number" string="Nro. Factura" />
                                <field name="invoice_cuf" string="CUF" />
                                <field name="invoice_cufd" string="CUFD" />
                                <field name="invoice_datetime" string="Fecha Emision" />
                                <field name="invoice_siat_id" string="Codigo Recepcion" />
                            </group>
                            <group id="header_right_group">
                                <field name="invoice_siat_url" string="SIAT URL" widget="url" />
                            </group>
                        </group>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>